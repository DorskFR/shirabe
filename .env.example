# shirabe configuration — every environment variable it reads.
# Copy to `.env` for local dev (`make run` / docker-compose pick it up).
# In the homelab these are provisioned from Vault (DATABASE_URL) + a configMap
# (the SHIRABE_* tunables); see the k8s overlay. `__` is not used — flat keys.

# REQUIRED. Postgres DSN for the MusicBrainz mirror. Use a *read-only* role:
# shirabe only runs SELECTs. Startup fails fast with a clear error if unset.
DATABASE_URL=postgres://readonly@musicbrainz.dorsk.dev/musicbrainz_db

# Optional. HTTP bind address:port. shirabe listens on 8800.
SHIRABE_BIND=0.0.0.0:8800

# Optional. Max Postgres connection-pool size. 8 is a sane production default
# for a single replica; raise alongside replica count / DB capacity.
SHIRABE_DB_POOL_SIZE=8

# Optional. Default `limit` applied to search endpoints when the client omits one.
SHIRABE_DEFAULT_LIMIT=25

# Optional. Hard cap on the `limit` a client may request.
SHIRABE_MAX_LIMIT=100

# Optional. pg_trgm similarity threshold (0.0-1.0). Rows below this are discarded.
SHIRABE_SIMILARITY_THRESHOLD=0.2

# Optional. tracing/`tracing_subscriber` EnvFilter. Defaults to `info` when unset.
# e.g. `info,shirabe=debug,tower_http=debug`.
RUST_LOG=info
